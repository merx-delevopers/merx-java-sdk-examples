# Token de integração Merx (sandbox). Solicite via support-api@merx.tech.
MERX_API_KEY=

# Ambiente: SANDBOX (default) ou PRODUCTION.
MERX_ENV=SANDBOX

# (Opcional) CAR real cadastrado no sandbox para os relatórios de carbono (CBIOS/EUDR/
# socioambiental) retornarem dados de verdade. Sem isto, um CAR fictício é usado.
MERX_SAMPLE_CAR=
